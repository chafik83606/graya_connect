# 1. Créez un projet sur https://supabase.com
# 2. Copiez ce fichier vers .env et remplissez les valeurs
# 3. Exécutez supabase/schema.sql dans l'éditeur SQL Supabase
# 4. Désactivez "Confirm email" dans Authentication > Providers > Email (pour tester plus vite)
# 5. Redémarrez Expo : npm start

EXPO_PUBLIC_SUPABASE_URL=https://votre-projet.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=votre-cle-anon-ici

# Actualités YouTube (optionnel — valeurs par défaut = chaîne Graya Officiel)
# EXPO_PUBLIC_YOUTUBE_CHANNEL_ID=UCKXEsEKicxBbPTZh7Qg3d_A
# EXPO_PUBLIC_YOUTUBE_MAX_VIDEOS=8
# EXPO_PUBLIC_YOUTUBE_API_KEY=cle-api-youtube-data-v3
#   → détection auto du live YouTube (sinon Graya lance le live depuis l'espace artiste)

# Instagram (@grayaofficial) — token Meta pour flux auto fiable
# 1. Compte Instagram Pro lié à une Page Facebook
# 2. developers.facebook.com → App → Instagram Graph API
# 3. Générer un token longue durée (instagram_basic, pages_read_engagement)
# EXPO_PUBLIC_INSTAGRAM_ACCESS_TOKEN=votre-token-ici
# EXPO_PUBLIC_INSTAGRAM_USERNAME=grayaofficial
# EXPO_PUBLIC_INSTAGRAM_MAX_POSTS=6
